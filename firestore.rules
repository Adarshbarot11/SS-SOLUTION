rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "adarshbarot0@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.sku is string && data.sku.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             (!('minStock' in data) || data.minStock is number);
    }

    function isValidInvoice(data) {
      return data.customerName is string && data.customerName.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.createdBy == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidInvoice(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /stockLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
